      "CELL 17\n",
      "================================================================================\n",
      "import numpy as np\n",
      "import matplotlib.pyplot as plt\n",
      "from mpl_toolkits.mplot3d import Axes3D  # noqa\n",
      "\n",
      "# thresholds\n",
      "thresholds = np.linspace(0, 1, 200)\n",
      "\n",
      "sn_list = []\n",
      "sp_list = []\n",
      "mcc_list = []\n",
      "\n",
      "for t in thresholds:\n",
      "    m = metrics_at_threshold(y_train, oof_prob, t)\n",
      "    sn_list.append(m[\"Sn\"])\n",
      "    sp_list.append(m[\"Sp\"])\n",
      "    mcc_list.append(m[\"MCC\"])\n",
      "\n",
      "sn_list = np.array(sn_list)\n",
      "sp_list = np.array(sp_list)\n",
      "mcc_list = np.array(mcc_list)\n",
      "\n",
      "fig = plt.figure(figsize=(10, 7))\n",
      "ax = fig.add_subplot(111, projection='3d')\n",
      "# X = threshold\n",
      "# Y = Sn\n",
      "# Z = MCC\n",
      "# color = Sp\n",
      "\n",

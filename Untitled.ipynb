      "\n",
      "================================================================================\n",
      "CELL 0\n",
      "================================================================================\n",
      "from Bio import SeqIO\n",
      "import pandas as pd\n",
      "import numpy as np\n",
      "import os\n",
      "import numpy as np\n",
      "import time\n",
      "from itertools import product\n",
      "from sklearn.model_selection import StratifiedKFold, train_test_split\n",
      "from xgboost import XGBClassifier\n",
      "import matplotlib.pyplot as plt\n",
      "from collections import Counter\n",
      "from matplotlib.backends.backend_pdf import PdfPages\n",
      "from sklearn.preprocessing import StandardScaler\n",
      "from sklearn.metrics import (\n",
      "    confusion_matrix, matthews_corrcoef, roc_auc_score,\n",
      "    roc_curve, auc, precision_recall_curve, average_precision_score\n",
      ")\n",
      "\n",
      "def load_fasta_to_df(fasta_path):\n",
      "    records = []\n",
      "    for record in SeqIO.parse(fasta_path, \"fasta\"):\n",
      "        seq = str(record.seq)\n",
      "        rid = record.id.lower()\n",
      "        if rid.startswith(\"pos\"):\n",
      "            label = 1\n",
      "        elif rid.startswith(\"neg\"):\n",
      "            label = 0\n",
      "        else:\n",
      "            raise ValueError(f\"Unknown label: {record.id}\")\n",
      "        records.append({\"sequence\": seq, \"label\": label})\n",
      "    return pd.DataFrame(records)\n",
      "\n",
      "train_df = load_fasta_to_df(\n",
      "    \"ToxicPeptidePrediction/ToxicPeptidePrediction-main/data/training_dataset.fasta\"\n",
      ")\n",
      "test_df = load_fasta_to_df(\n",
      "    \"ToxicPeptidePrediction/ToxicPeptidePrediction-main/data/independent_dataset.fasta\"\n",
      ")\n",
      "y_train = train_df[\"label\"].values\n",
      "y_test  = test_df[\"label\"].values\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 1\n",
      "================================================================================\n",
      "import numpy as np\n",
      "\n",
      "X_train = np.load(\"toxteller data embedding/protbert_train.npy\")\n",
      "X_test  = np.load(\"toxteller data embedding/protbert_test.npy\")\n",
      "\n",
      "print(X_train.shape, X_test.shape)\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 2\n",
      "================================================================================\n",
      "def eval_with_threshold(y_true, prob, thr):\n",
      "    y_pred = (prob >= thr).astype(int)\n",
      "    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()\n",
      "\n",
      "    Sn = tp / (tp + fn + 1e-9)\n",
      "    Sp = tn / (tn + fp + 1e-9)\n",
      "    MCC = matthews_corrcoef(y_true, y_pred)\n",
      "\n",
      "    return {\n",
      "        \"thr\": thr,\n",
      "        \"Sn\": Sn,\n",
      "        \"Sp\": Sp,\n",
      "        \"MCC\": MCC\n",
      "    }\n",
      "\n",
      "\n",
      "def scan_thresholds(y_true, prob):\n",
      "    rows = []\n",
      "    for thr in np.linspace(0.1, 0.9, 81):\n",
      "        rows.append(eval_with_threshold(y_true, prob, thr))\n",
      "\n",
      "    best = max(rows, key=lambda x: x[\"MCC\"])\n",
      "    return rows, best\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 3\n",
      "================================================================================\n",
      "#مدل بعدی\n",
      "\n",
      "================================================================================\n",
      "CELL 4\n",
      "================================================================================\n",
      "import numpy as np\n",
      "from collections import Counter\n",
      "\n",
      "AMINO_ACIDS = \"ACDEFGHIKLMNPQRSTVWY\"\n",
      "\n",
      "def aac(seq):\n",
      "    seq = seq.upper()\n",
      "    L = len(seq)\n",
      "    cnt = Counter(seq)\n",
      "    return np.array([cnt[aa] / L for aa in AMINO_ACIDS])\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 5\n",
      "================================================================================\n",
      "def dpc(seq):\n",
      "    seq = seq.upper()\n",
      "    L = len(seq)\n",
      "    pairs = [seq[i:i+2] for i in range(L-1)]\n",
      "    cnt = Counter(pairs)\n",
      "    return np.array([\n",
      "        cnt[a+b] / (L-1)\n",
      "        for a in AMINO_ACIDS\n",
      "        for b in AMINO_ACIDS\n",
      "    ])\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 6\n",
      "================================================================================\n",
      "def build_aac_dpc(df):\n",
      "    feats = []\n",
      "    for seq in df[\"sequence\"]:\n",
      "        feats.append(\n",
      "            np.concatenate([aac(seq), dpc(seq)])\n",
      "        )\n",
      "    return np.vstack(feats)\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 7\n",
      "================================================================================\n",
      "X_train_aacdpc = build_aac_dpc(train_df)\n",
      "X_test_aacdpc  = build_aac_dpc(test_df)\n",
      "\n",
      "print(X_train_aacdpc.shape)  # (4129, 420)\n",
      "print(X_test_aacdpc.shape)   # (200, 420)\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 8\n",
      "================================================================================\n",
      "from sklearn.preprocessing import StandardScaler\n",
      "\n",
      "scaler = StandardScaler()\n",
      "X_train_aacdpc = scaler.fit_transform(X_train_aacdpc)\n",
      "X_test_aacdpc  = scaler.transform(X_test_aacdpc)\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 9\n",
      "================================================================================\n",
      "from sklearn.decomposition import PCA\n",
      "from sklearn.preprocessing import StandardScaler\n",
      "\n",
      "# 1. scale\n",
      "scaler_bert = StandardScaler()\n",
      "X_train_bert = scaler_bert.fit_transform(X_train)\n",
      "X_test_bert  = scaler_bert.transform(X_test)\n",
      "\n",
      "# 2. PCA\n",
      "pca = PCA(n_components=256, random_state=42)\n",
      "X_train_bert_pca = pca.fit_transform(X_train_bert)\n",
      "X_test_bert_pca  = pca.transform(X_test_bert)\n",
      "\n",
      "X_train_combo = np.hstack([X_train_bert_pca, X_train_aacdpc])\n",
      "X_test_combo  = np.hstack([X_test_bert_pca,  X_test_aacdpc])\n",
      "\n",
      "print(X_train_combo.shape)\n",
      "# (4129, 256 + 420 = 676)\n",
      "\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 10\n",
      "================================================================================\n",
      "def select_threshold(y_true, y_prob, sn_min=0.85):\n",
      "    thresholds = np.linspace(0.05, 0.95, 181)\n",
      "    records = []\n",
      "\n",
      "    for thr in thresholds:\n",
      "        res = eval_with_threshold(y_true, y_prob, thr)\n",
      "        records.append({\n",
      "            \"thr\": thr,\n",
      "            \"Sn\": res[\"Sn\"],\n",
      "            \"Sp\": res[\"Sp\"],\n",
      "            \"MCC\": res[\"MCC\"]\n",
      "        })\n",
      "\n",
      "    valid = [r for r in records if r[\"Sn\"] >= sn_min]\n",
      "\n",
      "    if len(valid) > 0:\n",
      "        best = max(valid, key=lambda x: x[\"MCC\"])\n",
      "    else:\n",
      "        best = max(records, key=lambda x: x[\"MCC\"])\n",
      "\n",
      "    return best\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 11\n",
      "================================================================================\n",
      "def metrics_at_threshold(y_true, prob, thr):\n",
      "    y_true = np.asarray(y_true).astype(int)\n",
      "    y_pred = (prob >= thr).astype(int)\n",
      "\n",
      "    tp = np.sum((y_true == 1) & (y_pred == 1))\n",
      "    tn = np.sum((y_true == 0) & (y_pred == 0))\n",
      "    fp = np.sum((y_true == 0) & (y_pred == 1))\n",
      "    fn = np.sum((y_true == 1) & (y_pred == 0))\n",
      "\n",
      "    sn = tp / (tp + fn + 1e-12)\n",
      "    sp = tn / (tn + fp + 1e-12)\n",
      "\n",
      "    denom = np.sqrt((tp+fp)*(tp+fn)*(tn+fp)*(tn+fn)) + 1e-12\n",
      "    mcc = ((tp * tn) - (fp * fn)) / denom\n",
      "\n",
      "    return {\"MCC\": float(mcc), \"Sn\": float(sn), \"Sp\": float(sp)}\n",
      "\n",
      "\n",
      "================================================================================\n",
      "CELL 12\n",
      "================================================================================\n",
      "import numpy as np\n",
      "from itertools import product\n",
      "from sklearn.model_selection import StratifiedKFold, train_test_split\n",
      "from xgboost import XGBClassifier\n",
      "\n",
      "\n",
      "def metrics_at_threshold(y_true, prob, thr):\n",
      "    y_true = np.asarray(y_true).astype(int)\n",
      "    y_pred = (prob >= thr).astype(int)\n",
      "\n",
      "    tp = np.sum((y_true == 1) & (y_pred == 1))\n",
      "    tn = np.sum((y_true == 0) & (y_pred == 0))\n",
      "    fp = np.sum((y_true == 0) & (y_pred == 1))\n",
      "    fn = np.sum((y_true == 1) & (y_pred == 0))\n",
      "\n",
      "    sn = tp / (tp + fn + 1e-12)\n",
      "    sp = tn / (tn + fp + 1e-12)\n",
      "\n",
      "    denom = np.sqrt((tp + fp) * (tp + fn) * (tn + fp) * (tn + fn)) + 1e-12\n",
      "    mcc = ((tp * tn) - (fp * fn)) / denom\n",
      "\n",
      "    return {\"Sn\": float(sn), \"Sp\": float(sp), \"MCC\": float(mcc)}\n",
      "\n",
      "\n",
      "def predict_proba_best_trees(model, X):\n",
      "    if hasattr(model, \"best_iteration\") and model.best_iteration is not None:\n",
      "        return model.predict_proba(\n",
      "            X, iteration_range=(0, model.best_iteration + 1)\n",
      "        )[:, 1]\n",
      "    return model.predict_proba(X)[:, 1]\n",
      "\n",
      "\n",
      "skf = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)\n",
      "\n",
      "N_ESTIMATORS_BIG = 6000\n",
      "EARLY_STOP = 300\n",
      "ES_SPLIT = 0.2\n",
      "\n",
      "\n",
      "param_grid = {\n",
      "    \"max_depth\": [2, 3],\n",
      "    \"min_child_weight\": [1],\n",
      "    \"gamma\": [0],\n",
      "    \"subsample\": [1.0],\n",
      "    \"colsample_bytree\": [1.0],\n",
      "    \"learning_rate\": [0.01, 0.02],\n",
      "    \"reg_alpha\": [0],\n",
      "    \"reg_lambda\": [5, 10],\n",
      "    \"scale_pos_weight\": [3, 4, 5],\n",
      "}\n",
      "\n",
      "\n",
      "grid_results = []\n",
      "\n",
      "for params in product(*param_grid.values()):\n",
      "    cfg = dict(zip(param_grid.keys(), params))\n",
      "\n",
      "    oof_prob = np.zeros(len(y_train))\n",
      "    best_iters = []\n",
      "\n",
      "    for tr_idx, val_idx in skf.split(X_train_combo, y_train):\n",
      "        X_tr_full, X_val = X_train_combo[tr_idx], X_train_combo[val_idx]\n",
      "        y_tr_full, y_val = y_train[tr_idx], y_train[val_idx]\n",
      "\n",
      "        X_tr, X_es, y_tr, y_es = train_test_split(\n",
      "            X_tr_full,\n",
      "            y_tr_full,\n",
      "            test_size=ES_SPLIT,\n",
      "            stratify=y_tr_full,\n",
      "            random_state=42,\n",
      "        )\n",
      "\n",
      "        model = XGBClassifier(\n",
      "            n_estimators=N_ESTIMATORS_BIG,\n",
      "            objective=\"binary:logistic\",\n",
      "            eval_metric=\"aucpr\",\n",
      "            random_state=42,\n",
      "            n_jobs=-1,\n",
      "            early_stopping_rounds=EARLY_STOP,\n",
      "            **cfg,\n",
      "        )\n",
      "\n",
      "        model.fit(\n",
      "            X_tr,\n",
      "            y_tr,\n",
      "            eval_set=[(X_es, y_es)],\n",
      "            verbose=False,\n",
      "        )\n",
      "\n",
      "        best_iters.append(model.best_iteration)\n",
      "        oof_prob[val_idx] = predict_proba_best_trees(model, X_val)\n",
      "\n",
      "    thr = select_threshold(y_train, oof_prob, sn_min=0.88)[\"thr\"]\n",
      "    m = metrics_at_threshold(y_train, oof_prob, thr)\n",
      "\n",
      "    grid_results.append(\n",
      "        {\n",
      "            **cfg,\n",
      "            \"thr\": thr,\n",
      "            \"oof_Sn\": m[\"Sn\"],\n",
      "            \"oof_Sp\": m[\"Sp\"],\n",
      "            \"oof_MCC\": m[\"MCC\"],\n",
      "            \"mean_best_iteration\": float(np.mean(best_iters)),\n",
      "        }\n",
      "    )\n",
      "\n",
      "\n",
      "\n",
      "best_row = max(grid_results, key=lambda d: (d[\"oof_Sn\"], -d[\"thr\"]))\n",
      "print(\n",
      "     f\"Valid | thr={best_row['thr']:.3f} | \"\n",
      "     f\"Sn={best_row['oof_Sn']:.3f} | \"\n",
      "     f\"Sp={best_row['oof_Sp']:.3f} | \"\n",
      "     f\"MCC={best_row['oof_MCC']:.3f}\"\n",
      ")\n",
      "\n",
      "X_tr, X_es, y_tr, y_es = train_test_split(\n",
      "    X_train_combo,\n",
      "    y_train,\n",
      "    test_size=0.2,\n",
      "    stratify=y_train,\n",
      "    random_state=42,\n",
      ")\n",
      "\n",
      "final_model = XGBClassifier(\n",
      "    n_estimators=N_ESTIMATORS_BIG,\n",
      "    objective=\"binary:logistic\",\n",
      "    eval_metric=\"aucpr\",\n",
      "    random_state=42,\n",
      "    n_jobs=-1,\n",
      "    early_stopping_rounds=EARLY_STOP,\n",
      "    **{k: best_row[k] for k in param_grid},\n",
      ")\n",
      "\n",
      "final_model.fit(\n",
      "    X_tr,\n",
      "    y_tr,\n",
      "    eval_set=[(X_es, y_es)],\n",
      "    verbose=False,\n",
      ")\n",
      "\n",
      "final_thr = best_row[\"thr\"]\n",
      "\n",
      "prob_test = predict_proba_best_trees(final_model, X_test_combo)\n",
      "m_test = metrics_at_threshold(y_test, prob_test, final_thr)\n",
      "\n",
      "print(\n",
      "    f\"TEST | thr={best_row['thr']:.3f} | \"\n",
      "    f\"Sn={m_test['Sn']:.3f} | \"\n",
      "    f\"Sp={m_test['Sp']:.3f} | \"\n",
      "    f\"MCC={m_test['MCC']:.3f}\"\n",
      ")\n",
      "\n",
      "\n",
